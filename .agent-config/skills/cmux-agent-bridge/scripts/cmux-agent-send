#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sys
import uuid

from cmux_agent_common import (
    DELIVERED_PATH,
    QUEUE_PATH,
    discover_agents,
    ensure_state_dir,
    format_prompt,
    inject,
    load_state,
    now_iso,
    read_surface,
    resolve_agent_surface,
    save_state,
    surface_ready,
)


def append_jsonl(path, row: dict) -> None:
    ensure_state_dir()
    with path.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(row, separators=(",", ":")) + "\n")


def build_message(args: argparse.Namespace) -> dict:
    return {
        "id": str(uuid.uuid4()),
        "created_at": now_iso(),
        "from": args.from_agent,
        "to": args.to,
        "type": args.type,
        "content": " ".join(args.content),
    }


def status(workspace_ref: str | None = None) -> int:
    state = load_state()
    print(json.dumps(state, indent=2, sort_keys=True))
    print(f"queue_path={QUEUE_PATH}")
    print(f"delivered_path={DELIVERED_PATH}")
    try:
        discovered, unmatched = discover_agents(workspace_ref=workspace_ref)
        print("live_discovered_agents=" + json.dumps(discovered, sort_keys=True))
        if unmatched:
            print(f"live_unmatched_surfaces={len(unmatched)} (titles that matched no known agent pattern):")
            for item in unmatched:
                print(f"  - {item['surface']} title={item['title']!r}")
    except RuntimeError as error:
        print(f"live_discovery_failed={error}")
    return 0


def discover(workspace_ref: str | None) -> int:
    discovered, unmatched = discover_agents(workspace_ref=workspace_ref)
    print(json.dumps({"discovered": discovered, "unmatched_surfaces": unmatched}, indent=2, sort_keys=True))
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(description="Send a CMUX agent handoff.")
    parser.add_argument("--from", dest="from_agent", default="codex-reviewer")
    parser.add_argument("--to", required=False, help="Agent id or CMUX surface ref")
    parser.add_argument("--type", default="handoff")
    parser.add_argument("--queue", action="store_true", help="Append to the local queue for cmux-agent-triggerd.")
    parser.add_argument("--force", action="store_true", help="Inject even if readiness heuristics say the surface is busy.")
    parser.add_argument("--status", action="store_true", help="Print configured surfaces, queue paths, and live-discovered agents.")
    parser.add_argument(
        "--discover",
        action="store_true",
        help="Print agents discovered live from `cmux tree --all` (classified by surface title), without sending.",
    )
    parser.add_argument(
        "--workspace",
        help="Limit live discovery to this CMUX workspace ref (default: caller's current workspace only).",
    )
    parser.add_argument("content", nargs="*")
    args = parser.parse_args()

    if args.status:
        return status(workspace_ref=args.workspace)
    if args.discover:
        return discover(workspace_ref=args.workspace)
    if not args.to:
        parser.error("--to is required unless --status/--discover is used")
    if not args.content:
        parser.error("message content is required")

    state = load_state()
    message = build_message(args)

    if args.queue:
        append_jsonl(QUEUE_PATH, message)
        print(json.dumps({"queued": True, "id": message["id"], "to": message["to"]}, indent=2))
        return 0

    surface = resolve_agent_surface(state, args.to, workspace_ref=args.workspace)
    read_surface(surface)
    ready, reason = surface_ready(args.to, surface)
    if not ready and not args.force:
        raise SystemExit(f"CMUX target is not ready: {args.to} ({surface}) - {reason}")
    inject(surface, format_prompt(message))
    append_jsonl(DELIVERED_PATH, {**message, "delivered_at": now_iso(), "surface": surface, "mode": "direct"})
    save_state(state)
    print(json.dumps({"delivered": True, "id": message["id"], "to": message["to"], "surface": surface}, indent=2))
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except RuntimeError as error:
        print(str(error), file=sys.stderr)
        raise SystemExit(1)
